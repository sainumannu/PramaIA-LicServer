# Nome dell'applicativo (usato nel logging, nei titoli UI)
APP_NAME=PramaIA Licensing Server
APP_ID=pramaia-licserver

# OBBLIGATORIO — deve corrispondere a PRAMAIA_JWT_SECRET del Portal
PRAMAIA_JWT_SECRET=

# URL del Portal (per redirect login)
PORTAL_URL=http://localhost:3080

# Portal API URL (per chiamate backend-to-backend)
PORTAL_API_URL=http://localhost:8080

# ⚠️ DOPO AVER CONFIGURATO QUESTO FILE:
# Esegui 'python register_to_portal.py' per registrare l'app sul Portal

# Porte
BACKEND_PORT=8030
FRONTEND_PORT=3030

# Database
DATABASE_URL=sqlite:///./pramaia-licserver.db

# License Signing Keys Directory
KEYS_DIR=./keys

# Mind integration (opzionale)
MIND_URL=http://localhost:8100
USE_MIND_INTEGRATION=false
